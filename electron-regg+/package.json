{
  "name": "electron-regg",
  "version": "1.0.0",
  "description": "Sistema de Registro e Outorga de Recursos Hídricos - Desktop",
  "author": "Fabrício José Barrozo",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dist": "set CSC_IDENTITY_AUTO_DISCOVERY=false && electron-builder --win portable"
  },
  "build": {
    "appId": "com.ueredeveloper.reegg",
    "productName": "REEG+",
    "files": [
      "**/*",
      "!node_modules/electron/**",
      "!node_modules/electron-reload/**",
      "!node_modules/electron-builder/**",
      "!services/json/**"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "portable": {
      "artifactName": "REEG+-portable.exe"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "electron-reload": "^2.0.0-alpha.1"
  },
  "dependencies": {
    "@turf/helpers": "^6.5.0",
    "echarts": "^5.6.0",
    "leaflet": "^1.9.4",
    "turf": "^3.0.14"
  }
}
